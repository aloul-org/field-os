# ── AI provider switch (anthropic | openai, default: anthropic) ──
# Picks which LLM powers estimating, lead scoring, voice receptionist, AI Coach/CFO,
# revenue-forecast narrative and copilot. Both providers' keys can be set at once —
# only the active one needs to be valid.
AI_PROVIDER=openai

# ── Anthropic (Claude API: estimating, scoring, coach, summarisation, vision) ──
ANTHROPIC_API_KEY=your_key_here

# ── OpenAI (Whisper transcription always; also estimating/coach/etc. when AI_PROVIDER=openai) ──
OPENAI_API_KEY=your_key_here

# ── Supabase ──
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ── Stripe ──
STRIPE_SECRET_KEY=your_key_here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your_key_here
STRIPE_WEBHOOK_SECRET=your_webhook_secret_here
STRIPE_PRICE_ID_STARTER=your_price_id_here
STRIPE_PRICE_ID_GROWTH=your_price_id_here
STRIPE_PRICE_ID_PRO=your_price_id_here
STRIPE_CONNECT_CLIENT_ID=your_connect_client_id_here

# ── Twilio (WhatsApp + SMS + Voice receptionist) ──
TWILIO_ACCOUNT_SID=your_sid_here
TWILIO_AUTH_TOKEN=your_token_here
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_SMS_FROM=+your_number_here

# ── Resend (transactional email) ──
RESEND_API_KEY=your_key_here
RESEND_FROM_EMAIL=hello@fieldos.ai

# ── Google Maps Platform (server) + Mapbox (client map render) ──
# Enable Distance Matrix API + Routes API (scheduling) and Places API (New) (review polling)
GOOGLE_MAPS_SERVER_KEY=your_server_key_here
NEXT_PUBLIC_MAPBOX_TOKEN=your_mapbox_token_here

# ── Cron / internal job auth ──
CRON_SECRET=your_cron_secret_here

# ── PDF generation (local dev only) ──
# Point at an installed Chrome/Edge so puppeteer-core can render PDFs locally.
# On Vercel this is unused (a bundled serverless Chromium is used instead).
# Windows example: C:\Program Files\Google\Chrome\Application\chrome.exe
PUPPETEER_EXECUTABLE_PATH=

# ── App ──
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=FieldOS AI
